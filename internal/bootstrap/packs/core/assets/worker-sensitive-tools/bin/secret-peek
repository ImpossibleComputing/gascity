#!/usr/bin/env bash
set -euo pipefail
shim_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
asset_root=$(CDPATH= cd -- "$shim_dir/../.." && pwd)
exec "$asset_root/scripts/worker-sensitive-tool-guard.sh" \
  --kind secret \
  --secret-class "${GC_SECRET_CLASS:-mayor-only}" \
  --real "${GC_REAL_SECRET_PEEK:-secret-peek.real}" \
  -- "$@"
